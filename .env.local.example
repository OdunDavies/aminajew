# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will never be committed.
# NEVER commit real secrets to version control.

# ─── Site ─────────────────────────────────────────────────────────────────────
# Your production domain (used for sitemap, robots.txt, JSON-LD, and payment callbacks)
NEXT_PUBLIC_SITE_URL=https://artsybrands.com

# ─── Admin Auth ───────────────────────────────────────────────────────────────
# Password the admin uses to log in
ADMIN_PASSWORD=your_admin_password_here

# Random 32-byte hex secret used to sign JWT session cookies
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET=your_random_64_char_hex_here

# ─── Currency ─────────────────────────────────────────────────────────────────
# NGN → USD exchange rate (e.g. 1600 means ₦1600 = $1)
# Update this when the rate changes — no code change needed
NEXT_PUBLIC_NGN_USD_RATE=1600

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# API key from https://resend.com
RESEND_API_KEY=re_your_api_key_here

# Email address that receives order notifications and contact form submissions
ADMIN_EMAIL=your@email.com

# Email address shown as the sender on outgoing emails (must be a verified Resend domain)
RESEND_FROM_EMAIL=hello@yourdomain.com

# ─── Payments (Paystack) ──────────────────────────────────────────────────────
# Secret key from https://dashboard.paystack.com — starts with sk_live_ or sk_test_
PAYSTACK_SECRET_KEY=sk_your_paystack_secret_key
